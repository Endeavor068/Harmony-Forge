rules_version = '2';
// Aligné sur la console Firebase actuelle : accès ouvert (tests / debug).
// Avant production, restreindre : allow write: if request.auth != null; (read public si besoin).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
