{
  "entities": {
    "Song": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Song",
      "type": "object",
      "description": "Represents a musical song or hymn with language-specific metadata and content.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Song entity."
        },
        "content": {
          "type": "object",
          "description": "Bilingual lyrics, metadata, and per-language sheet music and audio.",
          "properties": {
            "en": {
              "$ref": "#/definitions/SongContent"
            },
            "fr": {
              "$ref": "#/definitions/SongContent"
            }
          }
        }
      },
      "required": [
        "id",
        "content"
      ],
      "definitions": {
        "SongContent": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "number": {
              "type": "string"
            },
            "author": {
              "type": "string"
            },
            "year": {
              "type": "string"
            },
            "key": {
              "type": "string",
              "description": "Musical key of the song (e.g., G Major)."
            },
            "verses": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "chorus": {
              "type": "string"
            },
            "partitionUrl": {
              "type": "string",
              "description": "URL or Data URI for sheet music (this language version)."
            },
            "audioUrl": {
              "type": "string",
              "description": "URL or Data URI for audio (this language version)."
            }
          },
          "required": [
            "title",
            "number",
            "verses"
          ]
        }
      }
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/songs/{songId}": {
      "schema": {
        "$ref": "#/backend/entities/Song"
      },
      "description": "Collection of all musical songs or hymns."
    }
  }
}