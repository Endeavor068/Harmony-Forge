
{
  "entities": {
    "Song": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Song",
      "type": "object",
      "description": "Represents a musical song or hymn with language-specific metadata and content.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Song entity."
        },
        "content": {
          "type": "object",
          "description": "Bilingual lyrics and metadata.",
          "properties": {
            "en": { "$ref": "#/definitions/SongContent" },
            "fr": { "$ref": "#/definitions/SongContent" }
          }
        },
        "partitionUrl": {
          "type": "string",
          "description": "URL or Data URI for the sheet music image."
        },
        "audioUrl": {
          "type": "string",
          "description": "URL or Data URI for the audio recording."
        }
      },
      "required": [
        "id",
        "content"
      ],
      "definitions": {
        "SongContent": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "number": { "type": "string" },
            "author": { "type": "string" },
            "year": { "type": "string" },
            "key": { "type": "string", "description": "Musical key of the song (e.g., G Major)." },
            "verses": {
              "type": "array",
              "items": { "type": "string" }
            },
            "chorus": { "type": "string" }
          },
          "required": ["title", "number", "verses"]
        }
      }
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/songs/{songId}": {
      "schema": {
        "$ref": "#/backend/entities/Song"
      },
      "description": "Collection of all musical songs or hymns."
    }
  }
}
