rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    /**
     * Chants partagés : lecture ouverte (catalogue consultable sans compte explicite),
     * création / mise à jour / suppression réservées aux utilisateurs authentifiés
     * (y compris anonymes), comme dans votre modèle « community ».
     */
    match /songs/{songId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.id == songId;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
