rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a Community-Managed Content model. The application functions as a 
     * shared digital hymnal where the barrier to contribution is authentication rather than 
     * individual ownership.
     */

    // --- Helper Functions ---

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the shared Song collection.
     * @path /songs/{songId}
     * @allow (read/write) If user is signed in.
     */
    match /songs/{songId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == songId;
      allow update: if isSignedIn() && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && resource != null;
    }

  }
}